{
  "name": "@axiom/desktop",
  "version": "0.1.1",
  "private": true,
  "description": "AXIOM Desktop — a single self-contained Tauri app (Chat · Space · Dashboard · IDE) over the real agent",
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "dev:vite": "vite",
    "build:vite": "tsc --noEmit && vite build",
    "prepare:agent-runtime": "node scripts/prepare-agent-runtime.mjs",
    "build:desktop": "npm run prepare:agent-runtime && npm run build:vite",
    "preview": "vite preview",
    "dev": "tauri dev",
    "build": "tauri build",
    "dist:mac": "tauri build --bundles dmg",
    "tauri": "tauri"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "6.0.3",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-go": "6.0.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-java": "6.0.2",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-php": "6.0.2",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/lang-rust": "6.0.2",
    "@codemirror/lang-sql": "6.10.0",
    "@codemirror/lang-vue": "0.1.3",
    "@codemirror/lang-wast": "6.0.2",
    "@codemirror/lang-xml": "6.1.0",
    "@codemirror/lang-yaml": "6.1.3",
    "@codemirror/legacy-modes": "6.5.3",
    "@codemirror/lint": "6.9.7",
    "@excalidraw/excalidraw": "0.17.6",
    "@excalidraw/mermaid-to-excalidraw": "2.2.2",
    "@tauri-apps/api": "2.11.0",
    "@uiw/react-codemirror": "4.25.10",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.2",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@vitejs/plugin-react": "4.7.0",
    "bun": "1.3.14",
    "typescript": "5.9.3",
    "vite": "7.3.5"
  }
}
